    {
      "id": "sfs-009",
      "type": "single",
      "scenario": "/dev/sda diskinin I/O istatistiklerini real-time izle.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "iostat -x 1 /dev/sda",
          "hint_text": "iostat -x extended stats, 1 saniye interval",
          "hint_partial": "iostat -x 1 ..."
        }
      ]
    },
    {
      "id": "sfs-010",
      "type": "multi-step",
      "scenario": "tmpfs olarak RAM'de geçici bir filesystem oluştur ve /mnt/ramdisk'e mount et.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "mkdir -p /mnt/ramdisk",
          "hint_text": "once mount noktasını oluştur",
          "hint_partial": "mkdir -p ..."
        },
        {
          "prompt": "$ ",
          "answer": "mount -t tmpfs -o size=512m tmpfs /mnt/ramdisk",
          "hint_text": "mount -t tmpfs ile RAM'de filesystem",
          "hint_partial": "mount -t tmpfs -o size=512m tmpfs ..."
        }
      ]
    },
    {
      "id": "sfs-011",
      "type": "single",
      "scenario": "Inode baskisi supesinde `/var` altindaki inode tuketimini directory bazinda buyukten kucuge sirala.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "du --inodes --max-depth=2 /var | sort -nr | head -20",
          "hint_text": "Inode sayisi icin `du --inodes`, sonra sayisal siralama kullan.",
          "hint_partial": "du --inodes --max-depth=2 /var ..."
        }
      ]
    },
    {
      "id": "sfs-012",
      "type": "single",
      "scenario": "`/var/lib` altindaki mount'lari target, source, fs tipi ve opsiyonlariyla recursive goster.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "findmnt -R -o TARGET,SOURCE,FSTYPE,OPTIONS /var/lib",
          "hint_text": "Recursive mount agaci icin `findmnt -R -o ...` kullan.",
          "hint_partial": "findmnt -R -o TARGET,SOURCE,FSTYPE,OPTIONS ..."
        }
      ]
    },
