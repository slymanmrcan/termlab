    {
      "id": "sctr-001",
      "type": "single",
      "scenario": "Running container'ların kısa ID ve image bilgisini custom format ile listele.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "docker ps --format \"{{.ID}} {{.Image}}\"",
          "hint_text": "Custom output için `docker ps --format` kullan.",
          "hint_partial": "docker ps --format ..."
        }
      ]
    },
    {
      "id": "sctr-002",
      "type": "single",
      "scenario": "web container'ının PID bilgisini çek ki host tarafında namespace debug yapabilesin.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "docker inspect --format '{{.State.Pid}}' web",
          "hint_text": "Tek field almak için `docker inspect --format` kullan.",
          "hint_partial": "docker inspect --format ..."
        }
      ]
    },
    {
      "id": "sctr-003",
      "type": "single",
      "scenario": "web container'ının network namespace'i içinde `ip addr` çalıştır.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "nsenter -t $(docker inspect --format \"{{.State.Pid}}\" web) -n ip addr",
          "hint_text": "Namespace girişi için `nsenter -t PID -n` kullan.",
          "hint_partial": "nsenter -t $(docker inspect ... ) -n ..."
        }
      ]
    },
    {
