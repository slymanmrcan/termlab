          "hint_partial": "docker build --no-cache -t ... ."
        },
        {
          "prompt": "$ ",
          "answer": "docker image prune",
          "hint_text": "Dangling image cleanup için `docker image prune` kullan.",
          "hint_partial": "docker image prune"
        }
      ]
    },
