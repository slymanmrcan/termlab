      "type": "multi-step",
      "scenario": "Bir image build cache'ini kullanmadan yeniden build al, sonra dangling image'ları temizle.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "docker build --no-cache -t myapp:latest .",
