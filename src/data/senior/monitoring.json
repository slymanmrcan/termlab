      "steps": [
        {
          "prompt": "$ ",
          "answer": "perf record -F 99 -a -g -- sleep 10",
          "hint_text": "System-wide sample toplamak icin `perf record -F 99 -a -g -- sleep 10` kullan.",
          "hint_partial": "perf record -F 99 -a -g -- ..."
        },
        {
          "prompt": "$ ",
          "answer": "perf report --stdio | head -40",
          "hint_text": "Interaktif ekran yerine metin raporu icin `perf report --stdio` kullan.",
          "hint_partial": "perf report --stdio ..."
        }
      ]
    },
