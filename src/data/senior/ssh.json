      "id": "sssh-001",
      "type": "single",
      "scenario": "Bastion üzerinden `ProxyJump` kullanarak app.internal host'una bağlan.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "ssh -J ops@bastion ops@app.internal",
          "hint_text": "`-J` ile jump host belirt.",
          "hint_partial": "ssh -J ... ..."
        }
      ]
    },
    {
      "id": "sssh-002",
      "type": "single",
      "scenario": "Local 1080 port'unda bir SOCKS proxy tunnel aç.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "ssh -D 1080 user@bastion",
          "hint_text": "Dynamic forwarding için `-D` kullan.",
          "hint_partial": "ssh -D 1080 ..."
        }
      ]
    },
    {
      "id": "sssh-003",
      "type": "single",
      "scenario": "Remote 8080 port'unu local 3000 port'una `reverse tunnel` ile yönlendir.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "ssh -R 8080:localhost:3000 user@10.0.0.5",
          "hint_text": "Reverse forwarding için `-R` kullan.",
          "hint_partial": "ssh -R 8080:localhost:3000 ..."
        }
      ]
    },
    {
      "id": "sssh-004",
      "type": "single",
      "scenario": "Connection multiplexing için `ControlMaster` ve `ControlPersist` ile background'da bir master session başlat.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "ssh -MNf -o ControlMaster=yes -o ControlPersist=10m -S ~/.ssh/cm-%r@%h:%p user@10.0.0.5",
          "hint_text": "`-MNf` ve `ControlMaster=yes` kombinasyonunu kullan.",
          "hint_partial": "ssh -MNf -o ControlMaster=yes ..."
        }
      ]
    },
    {
      "id": "sssh-005",
      "type": "single",
      "scenario": "`scp` ile bastion üzerinden app.internal host'una file kopyala.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "scp -J ops@bastion app.tar ops@app.internal:/tmp/",
          "hint_text": "`scp -J` ile jump host kullan.",
          "hint_partial": "scp -J ... ...:/tmp/"
        }
      ]
    },
