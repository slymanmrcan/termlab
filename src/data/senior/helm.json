      "id": "shelm-003",
      "type": "single",
      "scenario": "Local chart'i `prod` namespace'ine kur ve namespace'i yoksa olustur.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "helm install web ./chart --namespace prod --create-namespace",
          "hint_text": "Namespace olusturarak kurulum icin ilgili flag'leri ekle.",
          "hint_partial": "helm install ..."
        }
      ]
    },
