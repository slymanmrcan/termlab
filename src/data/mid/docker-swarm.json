      "scenario": "`web` service replica sayisini 5'e cek.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "docker service scale web=5",
          "hint_text": "Scale icin `docker service scale service=n` kullan.",
          "hint_partial": "docker service scale ..."
        }
      ]
    },
