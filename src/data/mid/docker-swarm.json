    {
      "id": "mds-001",
      "type": "single",
      "scenario": "`web` adinda 3 replica'li ve 80 portu publish edilmis nginx service olustur.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "docker service create --name web --replicas 3 -p 80:80 nginx",
          "hint_text": "Replica ve port icin ilgili flag'leri birlestir.",
          "hint_partial": "docker service create ..."
        }
      ]
    },
    {
      "id": "mds-002",
      "type": "single",
      "scenario": "`web` service image'ini `nginx:alpine` olarak guncelle.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "docker service update --image nginx:alpine web",
          "hint_text": "Image degisimi icin `docker service update --image` kullan.",
          "hint_partial": "docker service update ..."
        }
      ]
    },
    {
