    {
      "id": "msh-001",
      "type": "single",
      "scenario": "`deploy.sh` komutunun stdout ve stderr output'unu ayrı file'lara yönlendir.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "./deploy.sh > deploy.out 2> deploy.err",
          "hint_text": "stdout için `>`, stderr için `2>` kullan.",
          "hint_partial": "./deploy.sh > ... 2> ..."
        }
      ]
    },
    {
      "id": "msh-002",
      "type": "single",
      "scenario": "config.env file'ında boş olmayan ve `#` ile başlamayan line'ları filtrele.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "grep -Ev '^#|^$' config.env",
          "hint_text": "Extended regex ile comment ve boş line'ları ele.",
          "hint_partial": "grep -Ev ..."
        }
      ]
    },
    {
      "id": "msh-003",
      "type": "multi-step",
      "scenario": "logs.txt file'ından ikinci column'u al, sonra unique sayımını göster.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "cut -d' ' -f2 logs.txt",
          "hint_text": "Delimiter olarak boşluk verip ikinci field'ı al.",
          "hint_partial": "cut -d' ' -f2 ..."
        },
        {
          "prompt": "$ ",
          "answer": "cut -d' ' -f2 logs.txt | sort | uniq -c",
          "hint_text": "Önce sırala, sonra `uniq -c` ile say.",
          "hint_partial": "cut -d' ' -f2 ... | sort | uniq -c"
        }
      ]
    },
    {
      "id": "msh-004",
      "type": "single",
      "scenario": "config.yml varsa `exists`, yoksa `missing` yazdır.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "if [ -f config.yml ]; then echo exists; else echo missing; fi",
          "hint_text": "`if` ve `-f` test operatörünü kullan.",
          "hint_partial": "if [ -f ... ]; then ..."
        }
      ]
    },
    {
      "id": "msh-005",
