      "type": "single",
      "scenario": "Tum host'lara `app.conf` dosyasini kopyala.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "ansible all -i inventory -m copy -a 'src=app.conf dest=/etc/app/app.conf'",
          "hint_text": "Copy module icin `-m copy -a` kullan.",
          "hint_partial": "ansible all ..."
        }
      ]
    },
