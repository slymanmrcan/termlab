    {
      "id": "mtext-008",
      "type": "single",
      "scenario": "server.log'daki her linedaki IP adreslerini maskele (son iki okteti gizle).",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "sed 's/\\([0-9]\\{1,3\\}\\.[0-9]\\{1,3\\}\\)\\.[0-9]\\{1,3\\}\\.[0-9]\\{1,3\\}/\\1.x.x/g' server.log",
          "hint_text": "sed ile regex yakalama group ve backreference kullan",
          "hint_partial": "sed 's/\\([0-9]\\{1,3\\}\\.[0-9]\\{1,3\\}\\)\\.[0-9]\\{1,3\\}\\.[0-9]\\{1,3\\}/\\1.x.x/g' ..."
