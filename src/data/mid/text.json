      "type": "multi-step",
      "scenario": "Uygulama logunda son 100 satirdaki WARN ve ERROR'lari ayir. Once filtrele, sonra kategoriye gore say.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "tail -n 100 app.log | grep -E 'WARN|ERROR'",
          "hint_text": "Son 100 satirda WARN ve ERROR filtrelemek icin mevcut pipe'i kullan.",
          "hint_partial": "tail -n 100 app.log | grep -E ..."
