        {
          "prompt": "$ ",
          "answer": "tail -n 100 app.log | grep -E 'WARN|ERROR' | cut -d' ' -f1 | sort | uniq -c",
          "hint_text": "Seviyeleri saymak icin filtre cikisindan ilk kolonu alip grupla.",
          "hint_partial": "tail -n 100 app.log | grep -E ... | cut ..."
        }
      ]
