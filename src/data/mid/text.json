    {
      "id": "mtext-001",
      "type": "multi-step",
      "scenario": "500 hatasi patlamis. Once toplam 500 sayisini al, sonra en son 20 adet 500 kaydini gor.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "grep -c ' 500 ' access.log",
          "hint_text": "Toplam 500 sayisi icin `grep -c` kullan.",
          "hint_partial": "grep -c ' 500 ' ..."
        },
        {
          "prompt": "$ ",
          "answer": "grep ' 500 ' access.log | tail -20",
          "hint_text": "En son 500 kayitlari icin filtreyi `tail -20` ile birlestir.",
          "hint_partial": "grep ' 500 ' access.log | tail -20"
        }
      ]
    },
    {
      "id": "mtext-002",
