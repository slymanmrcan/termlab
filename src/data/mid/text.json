    {
      "id": "mtext-003",
      "type": "multi-step",
      "scenario": "error.log file'indeki her line'a tarih ekleyerek yeni bir file'a kaydet.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "while IFS= read -r line; do echo \"$(date '+%Y-%m-%d') $line\"; done < error.log > error_dated.log",
          "hint_text": "while read ile line line oku, date ile prefix ekle",
          "hint_partial": "while IFS= read -r line; do echo \"$(date '+%Y-%m-%d') $line\"; done < error.log > ..."
        }
      ]
    },
