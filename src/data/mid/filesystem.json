    {
      "id": "mfs-009",
      "type": "single",
      "scenario": "/var/log/ altında permission sorunu olmadan tüm file'lari bul (permission denied hatalarını gizle).",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "find /var/log/ -type f 2>/dev/null",
