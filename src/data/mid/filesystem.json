  "questions": [
    {
      "id": "mfs-001",
      "type": "multi-step",
      "scenario": "Production sunucusunda /var/log directory dolmaya başladı. Önce en çok yer kaplayan 5 file'ı bul, sonra en eskisini sil.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "du -sh /var/log/* | sort -rh | head -5",
          "hint_text": "du ile boyut, sort -rh ile büyükten küçüğe, head ile ilk 5",
          "hint_partial": "du -sh /var/log/* | sort -rh | ..."
        },
        {
          "prompt": "$ ",
          "answer": "ls -lt /var/log/ | tail -1",
          "hint_text": "ls -t zamana göre sıralar, tail -1 en eski",
          "hint_partial": "ls -lt /var/log/ | ..."
        }
      ]
    },
    {
      "id": "mfs-002",
      "type": "single",
      "scenario": "/app directory altında son 7 günde değiştirilmiş tüm .log file'larını bul.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "find /app -name '*.log' -mtime -7",
          "hint_text": "find ile -name pattern, -mtime -7 son 7 gün",
          "hint_partial": "find /app -name '*.log' ..."
        }
      ]
    },
    {
      "id": "mfs-003",
      "type": "single",
      "scenario": "/tmp altındaki 100MB'dan büyük file'lari bul.",
