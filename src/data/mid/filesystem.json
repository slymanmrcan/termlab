    {
      "id": "mfs-005",
      "type": "single",
      "scenario": "Bir directory'deki tüm .txt file'larını /archive/ directoryüne taşı.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "find . -name '*.txt' -exec mv {} /archive/ \\;",
          "hint_text": "find ile -exec kullanarak her file'a mv uygula",
          "hint_partial": "find . -name '*.txt' -exec mv {} /archive/ ..."
        }
      ]
    },
