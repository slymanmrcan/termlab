    {
      "id": "mssh-001",
      "type": "single",
      "scenario": "SSH config'teki `app` alias'inin hangi host, user ve identityfile ile cozuldgunu dogrula.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "ssh -G app | grep -E '^(hostname|user|identityfile) '",
          "hint_text": "Baglanti acmadan cozulmus konfigurasyonu gormek icin `ssh -G` kullan.",
          "hint_partial": "ssh -G app | grep -E '^(hostname|user|identityfile) '"
        }
      ]
    },
    {
      "id": "mssh-002",
      "type": "single",
      "scenario": "Local 5432 port'unu remote db.internal:5432'ye `local port forwarding` ile yönlendir.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "ssh -L 5432:db.internal:5432 user@bastion",
          "hint_text": "`ssh -L local:target:remoteport` kullan.",
          "hint_partial": "ssh -L 5432:..."
        }
      ]
    },
    {
      "id": "mssh-003",
      "type": "single",
      "scenario": "Remote host üzerinde tek komut olarak `uptime` çalıştır.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "ssh user@10.0.0.5 uptime",
