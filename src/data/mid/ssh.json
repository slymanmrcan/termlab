      "scenario": "SSH public key fingerprint'ini göster.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "ssh-keygen -lf ~/.ssh/id_ed25519.pub",
          "hint_text": "`ssh-keygen -lf` fingerprint gösterir.",
          "hint_partial": "ssh-keygen -lf ..."
        }
      ]
    },
