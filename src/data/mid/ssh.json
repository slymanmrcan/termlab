    {
      "id": "mssh-004",
      "type": "single",
      "scenario": "Current directory'yi remote /opt/app/ directory'sine `rsync` ile senkronize et.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "rsync -avz . user@10.0.0.5:/opt/app/",
          "hint_text": "`rsync -avz source target` kullan.",
          "hint_partial": "rsync -avz . ...:/opt/app/"
        }
      ]
    },
