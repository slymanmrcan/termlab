    {
      "id": "msys-001",
      "type": "multi-step",
      "scenario": "Sistem yavaş, önce load average kontrol et, sonra en fazla kaynak tüketen process'leri gör.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "uptime",
          "hint_text": "load average buradan görülür",
          "hint_partial": "upti..."
        },
        {
          "prompt": "$ ",
          "answer": "ps aux --sort=-%mem | head -10",
          "hint_text": "ps aux'u memory'ye göre sırala",
          "hint_partial": "ps aux --sort=-%mem | ..."
        }
      ]
    },
    {
      "id": "msys-002",
      "type": "single",
      "scenario": "nginx'in son bootden bu yana tüm loglarını gör.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "journalctl -u nginx -b",
          "hint_text": "journalctl -u service adı, -b bu boot'tan itibaren",
          "hint_partial": "journalctl -u nginx ..."
        }
      ]
    },
    {
      "id": "msys-003",
      "type": "single",
      "scenario": "Nginx incident'inda sadece bu boot'a ait warning ve error loglarini canli izle.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "journalctl -u nginx -b -p warning -f",
          "hint_text": "Servis, boot, seviye ve follow filtrelerini birlikte kullan.",
          "hint_partial": "journalctl -u nginx -b -p warning -f"
        }
      ]
    },
    {
      "id": "msys-004",
      "type": "multi-step",
      "scenario": "Kernel parametresi vm.swappiness'i geçici olarak 10'a düşür, sonra kalıcı hale getir.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "sysctl -w vm.swappiness=10",
          "hint_text": "sysctl -w runtime'da parametre yazar",
          "hint_partial": "sysctl -w ..."
        },
        {
          "prompt": "$ ",
          "answer": "echo 'vm.swappiness=10' >> /etc/sysctl.conf",
          "hint_text": "kalıcı için /etc/sysctl.conf'a ekle",
          "hint_partial": "echo 'vm.swappiness=10' >> ..."
        }
      ]
    },
    {
