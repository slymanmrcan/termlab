    {
      "id": "mproc-001",
      "type": "multi-step",
      "scenario": "Service çökmüş, hangi process en fazla CPU yiyor bul ve sonlandır.",
      "steps": [
        {
          "prompt": "$ ",
          "answer": "ps aux --sort=-%cpu | head -5",
          "hint_text": "ps aux'u CPU'ya göre sırala, ilk 5",
          "hint_partial": "ps aux --sort=-%cpu | ..."
        },
        {
          "prompt": "$ ",
          "answer": "kill -9 $(pgrep -f runaway_process)",
          "hint_text": "pgrep -f ile PID bul, kill -9 ile sonlandır",
          "hint_partial": "kill -9 $(pgrep -f ...)"
        }
      ]
    },
    {
      "id": "mproc-002",
